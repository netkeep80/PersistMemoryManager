# Doxyfile for PersistMemoryManager
# Generates API documentation from the include/ folder only.

PROJECT_NAME           = "PersistMemoryManager"
PROJECT_NUMBER         = 6.1.0
PROJECT_BRIEF          = "Multi-header C++17 persistent heap memory manager"

OUTPUT_DIRECTORY       = doxygen-output

# Only document the public API headers
INPUT                  = include
RECURSIVE              = YES

# Source file patterns
FILE_PATTERNS          = *.h *.hpp

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

# No need for LaTeX
GENERATE_LATEX         = NO
GENERATE_HTML          = YES

# HTML output settings
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT

# Enable graphs (class diagrams, call graphs)
HAVE_DOT               = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             =

# Warnings
WARN_IF_UNDOCUMENTED   = NO
WARN_NO_PARAMDOC       = NO

# Quiet mode (less noise in CI)
QUIET                  = YES
WARNINGS               = YES
